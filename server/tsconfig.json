{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "skipLibCheck": true,

    //expand rootDir to accept shared type//
    "rootDir": "..",
  
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },

  "include": ["src"]
}